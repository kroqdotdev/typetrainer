{
  "name": "typetrainer",
  "private": true,
  "type": "module",
  "description": "Learn to code in any language",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "pnpm --filter @typetrainer/web dev",
    "build": "pnpm --filter @typetrainer/web build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
